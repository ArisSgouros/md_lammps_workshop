# -------------------------
# Density profile along z
# -------------------------

compute         CZBIN all chunk/atom bin/1d z lower ${dz} units box
compute         CZBIN all chunk/atom bin/1d z lower 0.1 units box
fix             FRHO all ave/chunk ${prof_every} ${prof_repeat} ${nprof} CZBIN density/number                 file ${fprof_z}
fix             FRHO all ave/chunk 100 ${prof_repeat} ${nprof} CZBIN density/number                 file ${fprof_z}
fix             FRHO all ave/chunk 100 500 ${nprof} CZBIN density/number                 file ${fprof_z}
fix             FRHO all ave/chunk 100 500 50000 CZBIN density/number                 file ${fprof_z}
fix             FRHO all ave/chunk 100 500 50000 CZBIN density/number                 file o.density_profile_z.dat
run             ${nprof}
run             50000
