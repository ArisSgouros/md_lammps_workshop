
# -------------------------
# Simulation box and slab
# -------------------------

lattice         fcc ${rho_liq}
lattice         fcc 0.8
Lattice spacing in x,y,z = 1.7099759 1.7099759 1.7099759

region          RBOX block 0 ${nxy} 0 ${nxy} 0 ${nz_box} units lattice
region          RBOX block 0 10 0 ${nxy} 0 ${nz_box} units lattice
region          RBOX block 0 10 0 10 0 ${nz_box} units lattice
region          RBOX block 0 10 0 10 0 30 units lattice
create_box      1 RBOX
Created orthogonal box = (0 0 0) to (17.099759 17.099759 51.299278)
  1 by 1 by 1 MPI processor grid

# Center the liquid slab in the larger z box.
variable        zlo_slab equal 0.5*(${nz_box}-${nz_slab})
variable        zlo_slab equal 0.5*(30-${nz_slab})
variable        zlo_slab equal 0.5*(30-10)
variable        zhi_slab equal 0.5*(${nz_box}+${nz_slab})
variable        zhi_slab equal 0.5*(30+${nz_slab})
variable        zhi_slab equal 0.5*(30+10)

region          RSLAB block 0 ${nxy} 0 ${nxy} ${zlo_slab} ${zhi_slab} units lattice
region          RSLAB block 0 10 0 ${nxy} ${zlo_slab} ${zhi_slab} units lattice
region          RSLAB block 0 10 0 10 ${zlo_slab} ${zhi_slab} units lattice
region          RSLAB block 0 10 0 10 10 ${zhi_slab} units lattice
region          RSLAB block 0 10 0 10 10 20 units lattice
create_atoms    1 region RSLAB
Created 4200 atoms
  using lattice units in orthogonal box = (0 0 0) to (17.099759 17.099759 51.299278)
  create_atoms CPU = 0.001 seconds

mass            1 ${mass}
mass            1 1

# -------------------------
# Interactions and output
# -------------------------

pair_style      lj/cut ${rc}
pair_style      lj/cut 2.5
pair_coeff      1 1 ${eps} ${sig} ${rc}
pair_coeff      1 1 1 ${sig} ${rc}
pair_coeff      1 1 1 1 ${rc}
pair_coeff      1 1 1 1 2.5
pair_modify     shift yes

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

thermo          ${thermo_every}
thermo          1000
thermo_style    custom step temp pe ke etotal pxx pyy pzz
thermo_modify   flush yes

dump            DALL all custom ${dump_every} ${fdump_all} id type x y z
dump            DALL all custom 5000 ${fdump_all} id type x y z
dump            DALL all custom 5000 o.dump.all.lammpstrj id type x y z
dump_modify     DALL sort id

minimize        1.0e-6 1.0e-8 10000 100000
