velocity        all create ${temp} ${seed} mom yes rot no dist gaussian
velocity        all create 0.7 ${seed} mom yes rot no dist gaussian
velocity        all create 0.7 12345 mom yes rot no dist gaussian

timestep        ${dt}
timestep        0.005

# Keep the slab from slowly drifting during long profile averaging.
fix             FMOM all momentum 100 linear 1 1 1

# -------------------------
# Equilibration
# -------------------------

fix             FNVT all nvt temp ${temp} ${temp} ${tdamp}
fix             FNVT all nvt temp 0.7 ${temp} ${tdamp}
fix             FNVT all nvt temp 0.7 0.7 ${tdamp}
fix             FNVT all nvt temp 0.7 0.7 0.5

print           "Equilibrating LJ free film"
Equilibrating LJ free film
run             ${nequil}
run             50000
