unfix           FRHO
uncompute       CZBIN

# -------------------------
# Surface tension from pressure tensor
# -------------------------

compute         CTEMP all temp
compute         CPRESS all pressure CTEMP

variable        pxx equal c_CPRESS[1]
variable        pyy equal c_CPRESS[2]
variable        pzz equal c_CPRESS[3]
variable        pn equal v_pzz
variable        pt equal 0.5*(v_pxx+v_pyy)

# For a slab with two interfaces:
#   gamma = Lz/2 * (P_N - P_T)
variable        gamma equal 0.5*lz*(v_pn-v_pt)

fix             FGAM all ave/time ${gamma_every} ${gamma_repeat} ${gamma_freq}                 v_pxx v_pyy v_pzz v_gamma                 file ${fgamma}
fix             FGAM all ave/time 100 ${gamma_repeat} ${gamma_freq}                 v_pxx v_pyy v_pzz v_gamma                 file ${fgamma}
fix             FGAM all ave/time 100 100 ${gamma_freq}                 v_pxx v_pyy v_pzz v_gamma                 file ${fgamma}
fix             FGAM all ave/time 100 100 10000                 v_pxx v_pyy v_pzz v_gamma                 file ${fgamma}
fix             FGAM all ave/time 100 100 10000                 v_pxx v_pyy v_pzz v_gamma                 file o.surface_tension_pressure_tensor.dat

thermo_style    custom step temp pe etotal v_pxx v_pyy v_pzz v_gamma
WARNING: New thermo_style command, previous thermo_modify settings will be lost (../output.cpp:1100)

print           "Production run: pressure-tensor surface tension"
