velocity        all create ${temp} ${seed} mom yes rot no dist gaussian
velocity        all create 1 ${seed} mom yes rot no dist gaussian
velocity        all create 1 12345 mom yes rot no dist gaussian
timestep        ${dt}
timestep        0.005

print           "Stage 1: NVT equilibration"
Stage 1: NVT equilibration
fix             FEQ all nvt temp ${temp} ${temp} ${tdamp}
fix             FEQ all nvt temp 1 ${temp} ${tdamp}
fix             FEQ all nvt temp 1 1 ${tdamp}
fix             FEQ all nvt temp 1 1 0.5

dump            DEQ all custom ${dump_every} ${fdump_eq} id type x y z
dump            DEQ all custom 10000 ${fdump_eq} id type x y z
dump            DEQ all custom 10000 o.dump.equil.lammpstrj id type x y z
dump_modify     DEQ sort id

run             ${nequil}
run             20000
