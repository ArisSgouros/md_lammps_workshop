
# -------------------------
# 2. Initial state
# -------------------------

lattice         fcc ${rho}
lattice         fcc 0.8
Lattice spacing in x,y,z = 1.7099759 1.7099759 1.7099759
region          RBOX block 0 ${ncell} 0 ${ncell} 0 ${ncell} units lattice
region          RBOX block 0 8 0 ${ncell} 0 ${ncell} units lattice
region          RBOX block 0 8 0 8 0 ${ncell} units lattice
region          RBOX block 0 8 0 8 0 8 units lattice
create_box      1 RBOX
Created orthogonal box = (0 0 0) to (13.679808 13.679808 13.679808)
  1 by 1 by 1 MPI processor grid
create_atoms    1 box
Created 2048 atoms
  using lattice units in orthogonal box = (0 0 0) to (13.679808 13.679808 13.679808)
  create_atoms CPU = 0.001 seconds
mass            1 ${mass}
mass            1 1

write_data      ${fdata_init}
write_data      o.data.init
System init for write_data ...
WARNING: Communication cutoff is 0.0. No ghost atoms will be generated. Energies and forces may be wrong and atoms may get lost. (../comm_brick.cpp:188)

variable        natoms equal count(all)
variable        lx_box equal lx
variable        ly_box equal ly
variable        lz_box equal lz
variable        rho_actual equal count(all)/vol

print           "Created LJ fluid"
Created LJ fluid
print           "Target rho* = ${rho}"
Target rho* = 0.8
print           "Actual rho* = ${rho_actual}"
Actual rho* = 0.8
print           "Number of atoms = ${natoms}"
Number of atoms = 2048
print           "Box lengths: Lx=${lx_box}, Ly=${ly_box}, Lz=${lz_box}"
Box lengths: Lx=13.6798075734136, Ly=13.6798075734136, Lz=13.6798075734136

# -------------------------
# 3. Interactions and thermo output
# -------------------------

pair_style      lj/cut ${rc}
pair_style      lj/cut 2.5
pair_coeff      1 1 ${eps} ${sig} ${rc}
pair_coeff      1 1 1 ${sig} ${rc}
pair_coeff      1 1 1 1 ${rc}
pair_coeff      1 1 1 1 2.5
pair_modify     shift yes

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

thermo          ${thermo_every}
thermo          1000
thermo_style    custom step time temp pe ke etotal press density
thermo_modify   flush yes

# -------------------------
# 4. Minimize and equilibrate
# -------------------------

print           "Stage 0: Energy minimization"
Stage 0: Energy minimization
min_style       fire
minimize        1.0e-6 1.0e-8 ${nmin} 100000
minimize        1.0e-6 1.0e-8 1000 100000
