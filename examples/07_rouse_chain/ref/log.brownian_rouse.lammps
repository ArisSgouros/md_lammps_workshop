
# -------------------------
# Read molecular system
# -------------------------

bond_style      harmonic
read_data       ${fdata_in}
read_data       in.data
Reading data file ...
  orthogonal box = (0 0 0) to (100 100 100)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  1024 atoms
  scanning bonds ...
  1 = max bonds/atom
  orthogonal box = (0 0 0) to (100 100 100)
  1 by 1 by 1 MPI processor grid
  reading bonds ...
  896 bonds
Finding 1-2 1-3 1-4 neighbors ...
  special bond factors lj:    0        0        0       
  special bond factors coul:  0        0        0       
     2 = max # of 1-2 neighbors
     2 = max # of 1-3 neighbors
     4 = max # of 1-4 neighbors
     6 = max # of special neighbors
  special bonds CPU = 0.000 seconds
  read_data CPU = 0.007 seconds

bond_coeff      1 ${kbond} 0.0
bond_coeff      1 1.5 0.0

# pair_style zero provides neighbor communication without pair forces.
pair_style      zero 10.0
pair_coeff      * * 10.0

comm_modify     cutoff 10.0

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# -------------------------
# Analytical reference values
# -------------------------

variable        dcm equal ${temp}/(${gamma}*${nbead})
variable        dcm equal 1/(${gamma}*${nbead})
variable        dcm equal 1/(10*${nbead})
variable        dcm equal 1/(10*8)
variable        ree2 equal (${nbead}-1.0)*${bond_b}*${bond_b}
variable        ree2 equal (8-1.0)*${bond_b}*${bond_b}
variable        ree2 equal (8-1.0)*1*${bond_b}
variable        ree2 equal (8-1.0)*1*1
variable        rg2 equal ((${nbead}*${nbead})-1.0)*${bond_b}*${bond_b}/(6.0*${nbead})
variable        rg2 equal ((8*${nbead})-1.0)*${bond_b}*${bond_b}/(6.0*${nbead})
variable        rg2 equal ((8*8)-1.0)*${bond_b}*${bond_b}/(6.0*${nbead})
variable        rg2 equal ((8*8)-1.0)*1*${bond_b}/(6.0*${nbead})
variable        rg2 equal ((8*8)-1.0)*1*1/(6.0*${nbead})
variable        rg2 equal ((8*8)-1.0)*1*1/(6.0*8)
variable        rg equal sqrt(v_rg2)
variable        taur equal ${gamma}*${bond_b}*${bond_b}*${nbead}*${nbead}/(3.0*PI*PI*${temp})
variable        taur equal 10*${bond_b}*${bond_b}*${nbead}*${nbead}/(3.0*PI*PI*${temp})
variable        taur equal 10*1*${bond_b}*${nbead}*${nbead}/(3.0*PI*PI*${temp})
variable        taur equal 10*1*1*${nbead}*${nbead}/(3.0*PI*PI*${temp})
variable        taur equal 10*1*1*8*${nbead}/(3.0*PI*PI*${temp})
variable        taur equal 10*1*1*8*8/(3.0*PI*PI*${temp})
variable        taur equal 10*1*1*8*8/(3.0*PI*PI*1)

print           "Brownian Rouse model"
Brownian Rouse model
print           "Temperature T = ${temp}"
Temperature T = 1
print           "Statistical segment length b = ${bond_b}"
Statistical segment length b = 1
print           "Translational friction gamma = ${gamma}"
Translational friction gamma = 10
print           "Number of beads per chain N = ${nbead}"
Number of beads per chain N = 8
print           "Expected chain self-diffusion D_cm = ${dcm}"
Expected chain self-diffusion D_cm = 0.0125
print           "Expected <Ree^2> = ${ree2}"
Expected <Ree^2> = 7
print           "Expected <Rg^2> = ${rg2}"
Expected <Rg^2> = 1.3125
print           "Expected Rg = ${rg}"
Expected Rg = 1.14564392373896
print           "Expected continuum tau_R = ${taur}"
Expected continuum tau_R = 21.6151858436987

# -------------------------
# Brownian dynamics
# -------------------------

timestep        ${dt}
timestep        0.002

# No velocity initialization and no fix nve are used: fix brownian is
# the overdamped time integrator.
fix             FBD all brownian ${temp} ${seed_bd} gamma_t ${gamma}
fix             FBD all brownian 1 ${seed_bd} gamma_t ${gamma}
fix             FBD all brownian 1 314159 gamma_t ${gamma}
fix             FBD all brownian 1 314159 gamma_t 10

# Velocity-based temperature and kinetic energy are not useful diagnostics
# for overdamped Brownian dynamics, so thermo output is kept minimal.
thermo          ${thermo_every}
thermo          1000
thermo_style    custom step time pe
thermo_modify   flush yes

run             ${nequil}
run             20000
Generated 0 of 3 mixed pair_coeff terms from geometric mixing rule
