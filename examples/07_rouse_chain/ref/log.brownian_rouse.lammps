# -------------------------
# Production trajectory
# -------------------------

reset_timestep  0

# Use unwrapped coordinates for chain-COM MSD and conformational analysis.
dump            DALL all custom ${dump_every} ${fdump_all} id mol type xu yu zu
dump            DALL all custom 1000 ${fdump_all} id mol type xu yu zu
dump            DALL all custom 1000 o.dump.all.lammpstrj id mol type xu yu zu
dump_modify     DALL sort id

run             ${nprod}
run             1000000
