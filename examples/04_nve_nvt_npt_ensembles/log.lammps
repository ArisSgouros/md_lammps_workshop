LAMMPS (10 Dec 2025 - Development - patch_10Dec2025-652-g3eacc1d145)
# ============================================================
# Example 04: NVE, NVT, NPT, and anisotropic barostatting
# ============================================================
#
# Aim:
#   Compare common MD ensembles using the same LJ fluid.
#   The earlier examples already introduced setup, variables, dumps,
#   and fixes, so comments here focus only on the ensemble changes.
#
# ============================================================

units           lj
dimension       3
boundary        p p p
atom_style      atomic

# -------------------------
# Parameters and files
# -------------------------

variable        rho equal 0.8
variable        temp_hi equal 1.0
variable        temp_lo equal 0.2
variable        press_iso equal 1.0
variable        press_z equal 1.5

variable        eps equal 1.0
variable        sig equal 1.0
variable        rc equal 2.5
variable        mass equal 1.0

variable        dt equal 0.005
variable        tdamp equal 0.5
variable        pdamp equal 5.0
variable        ncell equal 8
variable        nmin equal 10000
variable        nrun equal 20000
variable        seed equal 12345

variable        thermo_every equal 500
variable        dump_every equal 100

variable        tag string ensembles
variable        flog string log.${tag}.lammps
variable        flog string log.ensembles.lammps
variable        fdump_all string o.dump.all.lammpstrj
variable        fdata_final string o.data.final

log             ${flog}
log             log.ensembles.lammps
