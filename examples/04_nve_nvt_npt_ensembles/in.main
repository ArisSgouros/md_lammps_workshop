# ============================================================
# Example 04: NVE, NVT, NPT, and anisotropic barostatting
# ============================================================
#
# Aim:
#   Compare common MD ensembles using the same LJ fluid.
#   The earlier examples already introduced setup, variables, dumps,
#   and fixes, so comments here focus only on the ensemble changes.
#
# ============================================================

units           lj
dimension       3
boundary        p p p
atom_style      atomic

# -------------------------
# Parameters and files
# -------------------------

variable        rho equal 0.8
variable        temp_hi equal 1.0
variable        temp_lo equal 0.2
variable        press_iso equal 1.0
variable        press_z equal 1.5

variable        eps equal 1.0
variable        sig equal 1.0
variable        rc equal 2.5
variable        mass equal 1.0

variable        dt equal 0.005
variable        tdamp equal 0.5
variable        pdamp equal 5.0
variable        ncell equal 8
variable        nmin equal 10000
variable        nrun equal 20000
variable        seed equal 12345

variable        thermo_every equal 500
variable        dump_every equal 100

variable        tag string ensembles
variable        flog string log.${tag}.lammps
variable        fdump_all string o.dump.all.lammpstrj
variable        fdata_final string o.data.final

log             ${flog}

# -------------------------
# System construction
# -------------------------

lattice         fcc ${rho}
region          RBOX block 0 ${ncell} 0 ${ncell} 0 ${ncell} units lattice
create_box      1 RBOX
create_atoms    1 box
mass            1 ${mass}

pair_style      lj/cut ${rc}
pair_coeff      1 1 ${eps} ${sig} ${rc}
pair_modify     shift yes

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

thermo          ${thermo_every}
thermo_style    custom step temp pe ke etotal pxx pyy pzz density lx ly lz
thermo_modify   flush yes

dump            DALL all custom ${dump_every} ${fdump_all} id type x y z
dump_modify     DALL sort id

minimize        1.0e-6 1.0e-8 ${nmin} 100000
velocity        all create ${temp_hi} ${seed} mom yes rot no dist gaussian
timestep        ${dt}

# ============================================================
# 1. NVE: constant N, V, E
# ============================================================
# Energy should be conserved up to integration error.

print           "Starting NVE run"
run             0

fix             FNVE all nve
run             ${nrun}
unfix           FNVE

# ============================================================
# 2. NVT: constant N, V, T
# ============================================================
# The thermostat exchanges energy with the system.

print           "Starting NVT run at high temperature"

fix             FNVT all nvt temp ${temp_hi} ${temp_hi} ${tdamp}
run             ${nrun}
unfix           FNVT

# ============================================================
# 3. NVT cooling
# ============================================================

print           "Starting NVT cooling run"

fix             FNVT all nvt temp ${temp_lo} ${temp_lo} ${tdamp}
run             ${nrun}
unfix           FNVT

# ============================================================
# 4. Isotropic NPT: lx, ly, and lz change together
# ============================================================

print           "Starting isotropic NPT run"

fix             FNPT all npt temp ${temp_lo} ${temp_lo} ${tdamp} iso ${press_iso} ${press_iso} ${pdamp}
run             ${nrun}
unfix           FNPT

# ============================================================
# 5. Fixed-LxLy PzzT: only lz is barostatted
# ============================================================
# Useful for slab/interface calculations when the lateral area is fixed.

print           "Starting fixed-LxLy PzzT run"

fix             FNPZZ all npt temp ${temp_lo} ${temp_lo} ${tdamp} z ${press_z} ${press_z} ${pdamp}
run             ${nrun}
unfix           FNPZZ

undump          DALL
write_data      ${fdata_final}

print           "Done."
