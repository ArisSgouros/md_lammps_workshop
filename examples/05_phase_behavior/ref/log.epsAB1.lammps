velocity        all create ${temp} ${seed} mom yes rot no dist gaussian
velocity        all create 1 ${seed} mom yes rot no dist gaussian
velocity        all create 1 12345 mom yes rot no dist gaussian
timestep        ${dt}
timestep        0.005

# -------------------------
# NVT run and partial RDFs
# -------------------------

fix             FNVT all nvt temp ${temp} ${temp} ${tdamp}
fix             FNVT all nvt temp 1 ${temp} ${tdamp}
fix             FNVT all nvt temp 1 1 ${tdamp}
fix             FNVT all nvt temp 1 1 0.5

run             ${nrun}
run             10000
