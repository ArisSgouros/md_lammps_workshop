# Partial RDFs: g_AA(r), g_AB(r), and g_BB(r).
compute         CRDF all rdf 200 1 1 1 2 2 2

fix             FRDF all ave/time ${rdf_every} ${rdf_repeat} ${rdf_freq} c_CRDF[*]                 file ${frdf} mode vector
fix             FRDF all ave/time 100 ${rdf_repeat} ${rdf_freq} c_CRDF[*]                 file ${frdf} mode vector
fix             FRDF all ave/time 100 50 ${rdf_freq} c_CRDF[*]                 file ${frdf} mode vector
fix             FRDF all ave/time 100 50 5000 c_CRDF[*]                 file ${frdf} mode vector
fix             FRDF all ave/time 100 50 5000 c_CRDF[*]                 file o.rdf.dat mode vector

run             ${nrdf}
run             10000
