
# -------------------------
# Mixed initial configuration
# -------------------------

lattice         fcc ${rho}
lattice         fcc 0.8
Lattice spacing in x,y,z = 1.7099759 1.7099759 1.7099759
region          RBOX block 0 ${ncell} 0 ${ncell} 0 ${ncell} units lattice
region          RBOX block 0 8 0 ${ncell} 0 ${ncell} units lattice
region          RBOX block 0 8 0 8 0 ${ncell} units lattice
region          RBOX block 0 8 0 8 0 8 units lattice
create_box      2 RBOX
Created orthogonal box = (0 0 0) to (13.679808 13.679808 13.679808)
  1 by 1 by 1 MPI processor grid
create_atoms    1 box
Created 2048 atoms
  using lattice units in orthogonal box = (0 0 0) to (13.679808 13.679808 13.679808)
  create_atoms CPU = 0.000 seconds

# Randomly convert half of the particles from type 1 to type 2.
set             group all type/fraction 2 0.5 ${seed}
set             group all type/fraction 2 0.5 12345
Setting atom values ...
  1024 settings made for type/fraction

mass            1 ${mass}
mass            1 1
mass            2 ${mass}
mass            2 1

group           GA type 1
1024 atoms in group GA
group           GB type 2
1024 atoms in group GB

print           "Binary LJ mixture"
Binary LJ mixture
print           "T* = ${temp}"
T* = 1
print           "rho* = ${rho}"
rho* = 0.8
print           "eps_aa = ${eps_aa}"
eps_aa = 1
print           "eps_bb = ${eps_bb}"
eps_bb = 1
print           "eps_ab = ${eps_ab}"
eps_ab = 1
print           "Number of GA particles = $(count(GA))"
Number of GA particles = 1024
print           "Number of GB particles = $(count(GB))"
Number of GB particles = 1024

# -------------------------
# Interactions and run setup
# -------------------------

pair_style      lj/cut ${rc}
pair_style      lj/cut 2.5
pair_coeff      1 1 ${eps_aa} ${sig} ${rc}
pair_coeff      1 1 1 ${sig} ${rc}
pair_coeff      1 1 1 1 ${rc}
pair_coeff      1 1 1 1 2.5
pair_coeff      1 2 ${eps_ab} ${sig} ${rc}
pair_coeff      1 2 1 ${sig} ${rc}
pair_coeff      1 2 1 1 ${rc}
pair_coeff      1 2 1 1 2.5
pair_coeff      2 2 ${eps_bb} ${sig} ${rc}
pair_coeff      2 2 1 ${sig} ${rc}
pair_coeff      2 2 1 1 ${rc}
pair_coeff      2 2 1 1 2.5
pair_modify     shift yes

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

thermo          ${thermo_every}
thermo          1000
thermo_style    custom step time temp pe ke etotal press density
thermo_modify   flush yes

dump            DALL all custom ${dump_every} ${fdump_all} id type x y z
dump            DALL all custom 5000 ${fdump_all} id type x y z
dump            DALL all custom 5000 o.dump.all.lammpstrj id type x y z
dump_modify     DALL sort id

minimize        1.0e-6 1.0e-8 10000 100000
